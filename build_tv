name: Build Simple Live TV APK

on:
  workflow_dispatch:
    inputs:
      flutter_version:
        description: 'Flutter SDK 版本'
        required: false
        default: '3.35.7'
      build_type:
        description: '构建类型'
        required: false
        default: 'release'
        type: choice
        options:
          - release
          - debug

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      # 1. 克隆仓库（包含子模块）
      - name: Clone repository
        uses: actions/checkout@v4
        with:
          path: dart_simple_live

      # 2. 配置 Java 环境
      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      # 3. 配置 Flutter 环境
      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: ${{ github.event.inputs.flutter_version || '3.35.7' }}
          channel: 'stable'
          cache: true

      # 4. 配置国内镜像加速依赖下载
      - name: Configure Flutter China mirrors
        run: |
          echo "PUB_HOSTED_URL=https://pub.flutter-io.cn" >> $GITHUB_ENV
          echo "FLUTTER_STORAGE_BASE_URL=https://storage.flutter-io.cn" >> $GITHUB_ENV

      # 5. 生成签名密钥（仅 release 构建需要）
      - name: Generate signing keystore
        if: github.event.inputs.build_type == 'release' || github.event.inputs.build_type == ''
        run: |
          cd dart_simple_live/simple_live_tv_app/android
          keytool -genkeypair \
            -v \
            -keystore release.keystore \
            -alias simple_live_tv \
            -keyalg RSA \
            -keysize 2048 \
            -validity 10000 \
            -storepass simple_live_2024 \
            -keypass simple_live_2024 \
            -dname "CN=Simple Live TV, OU=Dev, O=SimpleLive, L=Unknown, ST=Unknown, C=CN"

          # 写入 key.properties 供 build.gradle 读取
          cat > key.properties << 'EOF'
          storeFile=release.keystore
          storePassword=simple_live_2024
          keyPassword=simple_live_2024
          keyAlias=simple_live_tv
          EOF

      # 6. 获取依赖
      - name: Install Flutter dependencies
        run: |
          cd dart_simple_live/simple_live_tv_app
          flutter pub get

      # 7. 构建 APK
      - name: Build APK (${{ github.event.inputs.build_type || 'release' }})
        run: |
          cd dart_simple_live/simple_live_tv_app
          BUILD_TYPE="${{ github.event.inputs.build_type || 'release' }}"
          if [ "$BUILD_TYPE" = "debug" ]; then
            flutter build apk --debug
          else
            flutter build apk --release
          fi

      # 8. 上传 APK 产物
      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: simple_live_tv_${{ github.event.inputs.build_type || 'release' }}_apk
          path: dart_simple_live/simple_live_tv_app/build/app/outputs/flutter-apk/*.apk
          retention-days: 30

      # 9. 输出构建信息
      - name: Build summary
        run: |
          echo "========================================"
          echo "  Simple Live TV APK Build Complete!"
          echo "========================================"
          echo ""
          echo "Build type:  ${{ github.event.inputs.build_type || 'release' }}"
          echo "Flutter ver: ${{ github.event.inputs.flutter_version || '3.35.7' }}"
          echo "App ID:      com.xycz.simple_live_tv"
          echo "Platform:    Android TV (Leanback)"
          echo ""
          echo "Download the APK from Artifacts above."
          echo "========================================"
